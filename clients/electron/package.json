{
  "name": "cashier-electron",
  "version": "1.0.0",
  "description": "收银系统 Windows 桌面客户端",
  "main": "dist/main/index.js",
  "author": "Cashier SaaS",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^11.0.0",
    "electron-updater": "^6.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.cashier.saas",
    "productName": "收银系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052"
    }
  }
}
